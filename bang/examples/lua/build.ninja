rule C-cc
  description = cc $out
  command = cc -c -MMD -MF $depfile -O2 -I$builddir/src -DLUA_USE_LINUX $in -o $out
  depfile = $out.d

rule C-ar
  description = ar $out
  command = ar -crs $out $in

rule C-so
  description = cc $out
  command = cc -shared -o $out $in

rule C-ld
  description = cc $out
  command = cc -s -o $out $in -lm -lm

