build $builddir/tmp/lua.tmp/src/lua.o: C-cc $builddir/src/lua.c
build $builddir/lua: C-ld $builddir/tmp/lua.tmp/src/lua.o $builddir/liblua.a

default $builddir/lua

######################################################################
# Installation
######################################################################

prefix = ~/.local

rule install
  description = INSTALL $in to $destdir
  command = mkdir -p $destdir && cp -v --force --preserve=mode,timestamp $in $destdir
  pool = console

build install-bin: install $builddir/lua
  destdir = $${DESTDIR}$${PREFIX:-$prefix}/bin
build install: phony install-bin

######################################################################
# Help
######################################################################

rule help
  description = help
  command = echo "Targets:"; $
            echo "  help      show this help message"; $
            echo "  install   install  in PREFIX or ~/.local"

build help: help

######################################################################
# Regenerate build.ninja when build.lua changes
######################################################################

rule bang
  command = bang -g "bang" $in -o $out
  generator = true

build build.ninja: bang build.lua
  pool = console
