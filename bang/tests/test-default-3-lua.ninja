# Ninja file generated by bang (https://codeberg.org/cdsoft/luax)
# .build/bin/bang.lua -g ".build/bin/bang.lua" -q bang/tests/test-default-3.lua -o .build/tests/bang/lua/test-default-3.ninja

builddir = .build
ninja_required_version = 1.11.1

$builddir = .build

rule cp
  command = cp $in $out

build bar: cp foo
build baz: cp foo
build all: phony bar baz

######################################################################
# Default target test
######################################################################

# no default target and no help/install/clean target => no generated default

######################################################################
# Regenerate .build/tests/bang/lua/test-default-3.ninja when bang/tests/test-default-3.lua changes
######################################################################

rule bang
  command = .build/bin/bang.lua -g ".build/bin/bang.lua" -q $in -o $out
  generator = true

build .build/tests/bang/lua/test-default-3.ninja: bang bang/tests/test-default-3.lua | .git/refs/tags
  pool = console
