# Ninja file generated by bang (https://codeberg.org/cdsoft/bang)
# .build/bang -g ".build/bang" -q test/test-default-3.lua -o .build/test/luax/test-default-3.ninja

builddir = .build
ninja_required_version = 1.11.1

$builddir = .build

rule cp
  command = cp $in $out

build bar: cp foo
build baz: cp foo
build all: phony bar baz

######################################################################
# Default target test
######################################################################

# no default target and no help/install/clean target => no generated default

######################################################################
# Regenerate .build/test/luax/test-default-3.ninja when test/test-default-3.lua changes
######################################################################

rule bang
  command = .build/bang -g ".build/bang" -q $in -o $out
  generator = true

build .build/test/luax/test-default-3.ninja: bang test/test-default-3.lua | .git/refs/tags
  pool = console
